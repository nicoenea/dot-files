# Core apps for this setup
tap "nikitabobko/tap"
tap "dimentium/autoraise"

cask "nikitabobko/tap/aerospace"            # tiling window manager
cask "ghostty"                              # terminal
cask "dimentium/autoraise/autoraiseapp"     # focus-follows-mouse (sbmpost/AutoRaise)
cask "font-hack-nerd-font"         # nerd font for p10k glyphs

brew "bat"                         # .zshrc aliases cat=bat
brew "tmux"                        # Ghostty tabs live in tmux (see tmux/.tmux.conf)

# Dev toolchain referenced in .zshrc
brew "pyenv"
brew "nvm"
brew "asdf"

# pyenv build deps (compiling a Python needs these headers)
brew "openssl@3"
brew "readline"
brew "sqlite3"
brew "xz"
